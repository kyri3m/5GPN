#!/bin/bash
# 5GPN 快捷管理命令
# 用法: 5g [命令]

CTL="/root/5GPN/install.sh"

case "${1:-menu}" in
    menu|m)
        echo ""
        echo "  ╔══════════════════════════════════╗"
        echo "  ║       5GPN 管理面板              ║"
        echo "  ╠══════════════════════════════════╣"
        echo "  ║  5g status    查看运行状态       ║"
        echo "  ║  5g exit      出口管理          ║"
        echo "  ║  5g dns       查看 DNS 配置      ║"
        echo "  ║  5g rules     更新 GFWList 规则   ║"
        echo "  ║  5g cert      续期证书          ║"
        echo "  ║  5g log <服务> 查看服务日志       ║"
        echo "  ║  5g restart   重启全部服务       ║"
        echo "  ║  5g fw        查看防火墙端口     ║"
        echo "  ║  5g bot       查看 Bot 状态      ║"
        echo "  ║  5g help       显示此面板        ║"
        echo "  ╚══════════════════════════════════╝"
        echo ""
        ;;

    status|s)
        echo ""
        echo "═══ 服务状态 ═══"
        for s in dnsdist sniproxy quic-proxy china-dns-race-proxy proxy-gateway-tgbot; do
            state=$(systemctl is-active "$s" 2>/dev/null || echo "unknown")
            icon="✅"
            [[ "$state" != "active" ]] && icon="❌"
            echo "  $icon $s ($state)"
        done
        echo ""
        cur=$(cat /root/5GPN/runtime/current-exit 2>/dev/null || echo "local")
        echo "  🌐 出口: $cur"
        echo ""
        ;;

    exit|e)
        bash "$CTL" --list-exits 2>/dev/null
        ;;

    dns|d)
        echo "🌍 国际 DNS: $(cat /etc/dnsdist/.remote_dns 2>/dev/null || echo ?)"
        echo "🇨🇳 国内 DNS: $(cat /etc/dnsdist/.local_dns 2>/dev/null || echo ?)"
        domain=$(cat /etc/dnsdist/.domain 2>/dev/null || echo "未设置")
        echo "🔗 DoT 域名: $domain"
        ;;

    rules|r)
        bash "$CTL" --update-rules
        ;;

    cert|c)
        bash "$CTL" --renew-cert
        ;;

    log|l)
        svc="${2:-dnsdist}"
        journalctl -u "$svc" -n 30 --no-pager -o short-iso
        ;;

    restart|re)
        echo "正在重启服务..."
        for s in dnsdist sniproxy quic-proxy china-dns-race-proxy proxy-gateway-tgbot; do
            systemctl restart "$s" 2>/dev/null
            echo "  ↻ $s"
        done
        echo "✅ 全部重启完成"
        ;;

    fw|f)
        echo "═══ 防火墙已开放端口 ═══"
        nft list chain inet filter input 2>/dev/null | grep -E "tcp|udp" | grep "accept" | grep -oP '(tcp|udp)\s+dport\s+\S+' | while read -r line; do
            echo "  $line"
        done
        echo ""
        ;;

    bot|b)
        systemctl status proxy-gateway-tgbot --no-pager -l 2>/dev/null | head -12
        ;;

    help|h|-h|--help)
        exec "$0" menu
        ;;

    *)
        exec "$0" menu
        ;;
esac

[Unit]
Description=Proxy Gateway Telegram control bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=/opt/proxy-gateway/etc/tgbot.env
ExecStart=/usr/bin/python3 /opt/proxy-gateway/bin/tgbot.py
Restart=on-failure
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target

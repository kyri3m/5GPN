[Unit]
Description=Proxy Gateway Telegram control bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# ${BASE_DIR} is the repo root — set by install.sh at render time
EnvironmentFile=${BASE_DIR}/runtime/tgbot.env
ExecStart=/usr/bin/python3 ${BASE_DIR}/tgbot.py
Restart=on-failure
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
